@model SinemaSalonu.Models.User

@{
    ViewBag.Title = "Kayıt Ol";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card bg-dark text-white rounded-0 border-light p-4 shadow-lg" style="border: 2px solid #555;">
            <h2 class="text-center text-uppercase fw-bold mb-4" style="letter-spacing: 2px;">Kayıt Ol</h2>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.Username, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control bg-secondary text-white rounded-0 border-0" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control bg-secondary text-white rounded-0 border-0" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-0 fw-bold">KAYIT OL</button>
                </div>
            }

            <div class="mt-3 text-center">
                <a href="@Url.Action("Login", "Account")" class="text-light text-decoration-none small">Zaten hesabınız var mı? Giriş Yapın</a>
            </div>
        </div>
    </div>
</div>
