<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SINEMA SALONU</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        body {
            background-color: #121212;
            color: #dcdcdc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar {
            border-bottom: 2px solid #b71c1c;
        }
        .card {
            background-color: #1e1e1e;
        }
        .btn-danger {
            background-color: #b71c1c;
            border-color: #b71c1c;
        }
        .btn-danger:hover {
            background-color: #d32f2f;
            border-color: #d32f2f;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-black">
        <div class="container">
            @Html.ActionLink("SS SINEMA SALONU", "Index", "Home", new { area = "" }, new { @class = "navbar-brand fw-bold text-uppercase", @style = "letter-spacing: 2px; color: #e53935;" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li>@Html.ActionLink("Filmler", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">Merhaba, <strong>@User.Identity.Name</strong></span>
                        </li>
                    }

                    @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin")
                    {
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Admin")" class="nav-link text-warning">Admin Panel</a>
                        </li>
                    }
                    else if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a href="@Url.Action("MyBookings", "Booking")" class="nav-link text-info">Biletlerim</a>
                        </li>
                    }

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Çıkış Yap", "Logout", "Account", new { area = "" }, new { @class = "nav-link" })
                        </li>
                    }
                    else
                    {
                        <li>@Html.ActionLink("Giriş Yap", "Login", "Account", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Kayıt Ol", "Register", "Account", new { area = "" }, new { @class = "nav-link" })</li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr style="border-color: #555;" />
        <footer>
            <p>&copy; @DateTime.Now.Year - SINEMA SALONU</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
