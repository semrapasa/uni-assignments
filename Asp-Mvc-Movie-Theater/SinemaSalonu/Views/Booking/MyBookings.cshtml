@model IEnumerable<SinemaSalonu.Models.Booking>

@{
    ViewBag.Title = "Biletlerim";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-0 mt-3" role="alert">
        <strong>Başarılı!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h2 class="text-uppercase fw-bold text-info mt-4 mb-4">BİLETLERİM</h2>

@if (!Model.Any())
{
    <div class="alert alert-dark rounded-0 border-secondary" role="alert">
        Henüz bilet almadınız. <a href="@Url.Action("Index", "Home")" class="alert-link text-danger">Filmlere göz atın!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-hover table-bordered border-secondary" style="border: 1px solid #444;">
            <thead class="text-uppercase text-light bg-secondary">
                <tr>
                    <th>Film</th>
                    <th>Tür</th>
                    <th>Vizyon Tarihi</th>
                    <th>Satın Alma Tarihi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fs-5 fw-bold">@item.Movie.Title</td>
                        <td class="align-middle">@item.Movie.Genre</td>
                        <td class="align-middle">@item.Movie.ReleaseDate.ToString("dd.MM.yyyy")</td>
                        <td class="align-middle">@item.BookingDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="align-middle">
                            @using (Html.BeginForm("Cancel", "Booking", new { id = item.Id }, FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-0 fw-bold" onclick="return confirm('Bu bileti iptal etmek istediğinize emin misiniz?');">
                                    İPTAL ET
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
