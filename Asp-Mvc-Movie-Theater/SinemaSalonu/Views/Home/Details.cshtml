@model SinemaSalonu.Models.Movie

@{
    ViewBag.Title = Model.Title;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card rounded-0 border-0 shadow-lg" style="height: 550px; overflow: hidden;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="@Model.Title">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white fs-3">
                        KV
                    </div>
                }
            </div>
        </div>
        <div class="col-md-8">
            <div class="p-4" style="background-color: rgba(30, 30, 30, 0.8); border-left: 5px solid #b71c1c;">
                <h1 class="display-4 fw-bold text-uppercase text-white mb-3">@Model.Title</h1>
                <div class="mb-4">
                    <span class="badge bg-danger rounded-0 fs-6 px-3 py-2">@Model.Genre</span>
                    <span class="text-secondary ms-2"><i class="bi bi-calendar"></i> @Model.ReleaseDate.ToString("dd MMMM yyyy")</span>
                </div>
                
                <h4 class="text-secondary text-uppercase mb-3" style="letter-spacing: 1px;">Özet</h4>
                <div class="lead text-light mb-5">
                    @Html.Raw(Model.Description)
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    using (Html.BeginForm("BuyTicket", "Booking", FormMethod.Post))
                    {
                         @Html.AntiForgeryToken()
                         @Html.Hidden("movieId", Model.Id)
                         <button type="submit" class="btn btn-danger btn-lg rounded-0 fw-bold px-5 py-3 shadow-lg" style="letter-spacing: 1px;">
                             BİLET AL
                         </button>
                    }
                }
                else
                {
                    <div class="alert alert-dark rounded-0 border-secondary d-flex align-items-center" role="alert">
                        <div>
                            Bilet almak için lütfen <a href="@Url.Action("Login", "Account")" class="alert-link text-danger fw-bold">giriş yapın</a>.
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
