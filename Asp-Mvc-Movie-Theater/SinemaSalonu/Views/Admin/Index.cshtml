@model IEnumerable<SinemaSalonu.Models.Movie>

@{
    ViewBag.Title = "Yönetim Paneli";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="text-uppercase fw-bold text-danger">FİLMLERİ YÖNET</h2>
    <a href="@Url.Action("Create")" class="btn btn-outline-danger fw-bold rounded-0">YENİ FİLM EKLE</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-hover table-bordered border-secondary" style="border: 1px solid #444;">
        <thead class="text-uppercase text-light bg-secondary">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Genre)</th>
                <th>@Html.DisplayNameFor(model => model.ReleaseDate)</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td class="align-middle fs-5 fw-bold">@Html.DisplayFor(modelItem => item.Title)</td>
                <td class="align-middle">@Html.DisplayFor(modelItem => item.Genre)</td>
                <td class="align-middle">@item.ReleaseDate.ToString("dd.MM.yyyy")</td>
                <td class="align-middle">
                    <div class="btn-group" role="group">
                        <a href="@Url.Action("Edit", new { id=item.Id })" class="btn btn-sm btn-warning rounded-0 fw-bold text-dark">DÜZENLE</a>
                        <a href="@Url.Action("Delete", new { id=item.Id })" class="btn btn-sm btn-danger rounded-0 fw-bold">SİL</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
